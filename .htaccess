# ToolNest Security & SEO Rules

# 1. Disable Directory Listing
Options -Indexes

# 2. Clean URLs
RewriteEngine On

# ── Static Page Clean URLs ──────────────────────
# /robots.txt    → robots.php (dynamic, aware of SITE_URL)
RewriteRule ^robots\.txt$      robots.php [L,QSA]
# /about            → about.php
RewriteRule ^about/?$           about.php [L,QSA]
# /contact          → contact.php
RewriteRule ^contact/?$         contact.php [L,QSA]
# /privacy-policy   → privacy-policy.php
RewriteRule ^privacy-policy/?$  privacy-policy.php [L,QSA]
# /terms            → terms.php
RewriteRule ^terms/?$           terms.php [L,QSA]
# /sitemap.xml      → sitemap.php (dynamic XML)
RewriteRule ^sitemap\.xml$      sitemap.php [L,QSA]

# Custom error pages
ErrorDocument 404 /tools/404.php

# ── Tool Paths ──────────────────────────────────
# /tools/image/compress-image   → tools/image/compress-image/index.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^tools/([^/]+)/([^/]+)/?$ tools/$1/$2/index.php [L,QSA]

# ── Block direct PHP execution in uploads/tmp ───
<FilesMatch "\.php$">
    <If "%{REQUEST_URI} =~ m#^/tools/(uploads|tmp)/#">
        Order Deny,Allow
        Deny from all
    </If>
</FilesMatch>

# ── Gzip Compression ────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/x-javascript application/json image/svg+xml
</IfModule>

# ── Browser Caching ─────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg          "access plus 1 year"
    ExpiresByType image/jpeg         "access plus 1 year"
    ExpiresByType image/gif          "access plus 1 year"
    ExpiresByType image/png          "access plus 1 year"
    ExpiresByType image/webp         "access plus 1 year"
    ExpiresByType image/x-icon       "access plus 1 year"
    ExpiresByType image/svg+xml      "access plus 1 month"
    ExpiresByType text/css           "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/x-javascript  "access plus 1 month"
    ExpiresDefault                   "access plus 2 days"
</IfModule>

# ── Security Headers ────────────────────────────
<IfModule mod_headers.c>
    Header set X-XSS-Protection       "1; mode=block"
    Header set X-Frame-Options         "SAMEORIGIN"
    Header set X-Content-Type-Options  "nosniff"
    Header set Referrer-Policy         "strict-origin-when-cross-origin"
    Header set Permissions-Policy      "geolocation=(), microphone=(), camera=()"
    # Remove server signature info
    Header unset Server
    Header unset X-Powered-By
</IfModule>

# ── Hide sensitive files ─────────────────────────
<FilesMatch "(^\.htaccess|composer\.(json|lock|phar)$|\.env$|\.git)">
    Order Allow,Deny
    Deny from all
</FilesMatch>
